# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# ── Android signing & secrets (NEVER commit) ──────────────────────────────────
android/key.properties
*.jks
*.keystore
android/local.properties
android/.gradle/
android/captures/

# ── iOS CocoaPods (regenerated by `pod install`) ──────────────────────────────
ios/Pods/
ios/.symlinks/



# ── Generated Dart files ──────────────────────────────────────────────────────
*.g.dart
*.freezed.dart
*.mocks.dart

# ── Flutter plugin registration (auto-generated) ─────────────────────────────
.flutter-plugins
lib/generated_plugin_registrant.dart

# ── macOS Flutter ephemeral ───────────────────────────────────────────────────
**/macos/Flutter/ephemeral/